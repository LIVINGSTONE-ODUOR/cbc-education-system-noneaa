# Server
PORT=3001
NODE_ENV=development

# Database / Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Optional: needed only for backend pg connection
# SUPABASE_DB_PASSWORD=your-supabase-database-password
# Optional DB overrides (only if needed)
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_HOST=db.your-project.supabase.co

# JWT / Auth
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME=30

# Frontend
FRONTEND_URL=http://localhost:5173

# OpenRouter / AI Assistant
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_URL=https://your-frontend-domain.example
OPENROUTER_APP_NAME=CBC Education Systems

# AI Runtime Controls
AI_REQUEST_TIMEOUT_MS=35000
AI_MAX_INPUT_CHARS=6000
AI_MAX_CONTEXT_MESSAGES=20
AI_USER_RATE_LIMIT_PER_MIN=20
AI_SCHOOL_RATE_LIMIT_PER_MIN=120
AI_MONTHLY_TOKEN_LIMIT_PER_SCHOOL=250000
AI_COST_INPUT_PER_1K=0.00015
AI_COST_OUTPUT_PER_1K=0.0006
AI_DEFAULT_TEMPERATURE=0.3
AI_DEFAULT_MAX_TOKENS=900
AI_ALLOW_FALLBACK=true

# Platform Security / Logging
REQUIRE_EMAIL_VERIFICATION=true
ENABLE_AUDIT_LOGGING=true
ENABLE_RATE_LIMITING=true
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
